# SubLearn Environment Configuration
# Copy this file to .env and fill in your actual values

# --- LLM API (Qwen3-Omni via DashScope, handles translation + ASR) ---
LLM_API_KEY=your_dashscope_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3-omni-flash

# --- Bilibili Cookie (optional, for member-only content) ---
# Paste your Bilibili cookie string here to access member-only videos
BILIBILI_COOKIE=

# --- Server ---
HOST=0.0.0.0
PORT=8000